# Supabase project credentials
# Find these in your Supabase project dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Required Supabase setup:
# 1. Enable Email OTP in Authentication → Providers → Email
#    - Disable "Confirm email" (not needed for OTP-only flow)
#    - Set OTP expiry to 600 seconds (10 minutes) in Auth → Email settings
# 2. Create a `profiles` table:
#    CREATE TABLE profiles (
#      id UUID PRIMARY KEY REFERENCES auth.users(id) ON DELETE CASCADE,
#      role TEXT NOT NULL CHECK (role IN (
#        'main_admin','company_admin','appointed_person',
#        'crane_supervisor','crane_operator','slinger_signaller','subcontractor_admin'
#      )),
#      full_name TEXT NOT NULL,
#      phone TEXT NOT NULL,
#      site_id UUID REFERENCES sites(id),
#      company_id UUID REFERENCES companies(id),
#      created_at TIMESTAMPTZ DEFAULT NOW()
#    );
# 3. Enable Row Level Security on all tables
# 4. See lib/supabase.ts for full schema comments
